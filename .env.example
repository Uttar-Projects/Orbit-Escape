# ============================================================
# Orbit Escape TMA — Environment Variables
# ============================================================
# LOCAL DEV:   cp .env.example .env  →  npm start
# PRODUCTION:  set these in your hosting dashboard (Railway / Render / VPS)
#              NEVER commit .env to git
# ============================================================

# ── Telegram ──────────────────────────────────────────────
# Get from @BotFather → /newbot
TELEGRAM_BOT_TOKEN=

# ── Server ────────────────────────────────────────────────
# "development" locally, "production" when deployed
NODE_ENV=development
PORT=3000

# ── PostgreSQL ────────────────────────────────────────────
# Railway:  copy DATABASE_URL from your PostgreSQL service → Variables tab
# Supabase: Settings → Database → Connection string (URI mode)
# Local:    postgresql://postgres:password@localhost:5432/orbit_escape
DATABASE_URL=postgresql://user:password@localhost:5432/orbit_escape

# ── Security ──────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# MUST be changed for production — never use the dev value in production
SESSION_SECRET=local-dev-change-me-before-production

# ── CORS ──────────────────────────────────────────────────
# Your deployed URL (no trailing slash). Localhost is always allowed in dev.
# Multiple: https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000

# ── Telegram Bot Username ─────────────────────────────────
# Used in the share button URL. Set in public/index.html → window.__BOT_USERNAME__
# BOT_USERNAME=YourBotUsername

# ── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_MAX=60

# ── Anti-Cheat ────────────────────────────────────────────
MAX_SCORE_PER_SECOND=2.0

# ── Monitoring (optional) ─────────────────────────────────
# Sentry: https://sentry.io → New Project → Node.js → copy DSN
# Leave empty to disable (app works fine without it)
SENTRY_DSN=

# ── Ads (optional) ────────────────────────────────────────
# Register at https://adsgram.ai → copy Block ID → public/index.html
# Adsgram Reward URL (after HTTPS deploy):
#   https://YOUR_DOMAIN/api/adsgram/reward?userid=[userId]
# PUBLIC_APP_URL=https://your-app.up.railway.app

# ── Logging ───────────────────────────────────────────────
LOG_LEVEL=info
